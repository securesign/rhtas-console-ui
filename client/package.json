{
  "name": "@console-ui/client",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf ./dist",
    "clean:all": "rimraf ./dist ./node_modules",
    "build": "npm run generate && tsc -b && vite build",
    "lint": "eslint --max-warnings 0 . && tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check --ignore-path ../.prettierignore './src/**/*.{ts,tsx,js,json}'",
    "format:fix": "prettier --write --ignore-path ../.prettierignore './src/**/*.{ts,tsx,js,json}'",
    "start:dev": "npm run generate && vite --port 3000 --host",
    "start": "vite preview",
    "test": "vitest --run",
    "coverage": "vitest run --coverage",
    "generate": "openapi-ts -f ./config/openapi-ts.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@patternfly/patternfly": "^6.5.2",
    "@patternfly/react-charts": "^8.5.1",
    "@patternfly/react-component-groups": "^6.5.0",
    "@patternfly/react-core": "^6.5.1",
    "@patternfly/react-table": "^6.5.1",
    "@patternfly/react-tokens": "^6.2.0",
    "@peculiar/x509": "1.14.3",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.85.0",
    "@tsd-ui/core": "^0.3.2",
    "@vitest/coverage-v8": "^4.1.9",
    "axios": "^1.18.0",
    "dayjs": "^1.11.7",
    "js-yaml": "^4.1.0",
    "pvtsutils": "^1.3.6",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.56.0",
    "react-router-dom": "^7.15.0",
    "react-syntax-highlighter": "^16.1.1",
    "rekor": "^0.2.0",
    "victory": "^37.3.4"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/file-saver": "^2.0.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.9",
    "jsdom": "^28.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.0",
    "vite-plugin-ejs": "^2.0.0",
    "vite-plugin-istanbul": "^9.0.1",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
